# Example environment variables file
# COPY THIS TO .env AND FILL IN YOUR ACTUAL VALUES
# NEVER COMMIT .env TO VERSION CONTROL

# Database (use strong, unique password)
DATABASE_URL=postgresql://username:CHANGE_ME_USE_STRONG_PASSWORD@host/database?sslmode=require

# Authentication (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_USE_RANDOM_SECRET_KEY_HERE
AUTH_SESSION_SECRET=CHANGE_ME_USE_ANOTHER_RANDOM_SECRET

# Admin (use strong, unique token)
ADMIN_EMAIL=your-email@example.com
READINESS_ADMIN_TOKEN=CHANGE_ME_USE_STRONG_RANDOM_TOKEN

# Frontend
FRONTEND_URL=http://localhost:4173
CORS_ORIGINS=http://localhost:4173,http://localhost:5173

# OAuth (get from Google Console)
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=CHANGE_ME_GET_FROM_GOOGLE_CONSOLE

# API Keys (keep secure, rotate regularly)
OPENAI_API_KEY=sk-CHANGE_ME_GET_FROM_OPENAI
OPENAI_MODEL_NAME=gpt-4

# Garmin (use strong encryption key)
GARMIN_EMAIL=your-garmin-email@example.com
GARMIN_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
GARMIN_PASSWORD_ENCRYPTION_KEY=CHANGE_ME_USE_FERNET_KEY

# Security Settings
ENVIRONMENT=production
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true

# IMPORTANT: Generate secure values with:
# Password: pwgen -s 32 1
# Secret: openssl rand -hex 32
# Fernet: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
